{
    "manifest_version": 3,
    "name": "Wider-Chatbots",
    "version": "1.1",
    "description": "A simple monochrome extension to make Gemini and ChatGPT wider.",
    "permissions": [
      "storage"
    ],
    "action": {
      "default_popup": "popup.html"
    },
    "content_scripts": [
      {
        "matches": [
          "https://gemini.google.com/*",
          "https://chatgpt.com/*"
        ],
        "js": ["content.js"]
      }
    ]
  }